# =============================================================================
# AUROSPACE Orders Demo - Environment Variables
# =============================================================================
# Copy to .env: cp .env.example .env
# Fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Rails ---
RAILS_ENV=development
RACK_ENV=development
RAILS_MAX_THREADS=5
PORT=3000
# Generate with: rails secret
SECRET_KEY_BASE=

# --- Database ---
DATABASE_URL=postgresql://aurospace:aurospace_dev@localhost:5432/aurospace_development
# Or separate variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=aurospace
# DB_PASSWORD=aurospace_dev
# DB_NAME=aurospace_development

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- YooKassa Payment Gateway ---
# Test mode: https://yookassa.ru/developers/payment-acceptance/testing-and-going-live/testing
# Get test credentials: https://yookassa.ru/my/shop-settings
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Webhook callback URL (use ngrok for local testing)
YOOKASSA_WEBHOOK_URL=https://your-domain.com/webhooks/yookassa
# Return URL after payment
YOOKASSA_RETURN_URL=https://your-domain.com/orders/:id

# --- Email (SMTP) ---
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=gmail.com
SMTP_USERNAME=
SMTP_PASSWORD=
# Or use a transactional email service:
# SMTP_ADDRESS=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USERNAME=your-postmark-api-token
# SMTP_PASSWORD=your-postmark-api-token

# --- Application ---
APP_HOST=localhost:3000
# Punycode version for external services that don't support Cyrillic domains
# APP_HOST_PUNYCODE=xn--80aaligecefbe9g.xn--p1ai

# --- Admin ---
ADMIN_EMAIL=admin@example.com
# ActiveAdmin Basic Auth (required for /admin access)
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Sidekiq ---
# SIDEKIQ_CONCURRENCY=5
# SIDEKIQ_WEB_USERNAME=admin
# SIDEKIQ_WEB_PASSWORD=

# --- Production only ---
# RAILS_SERVE_STATIC_FILES=true
# RAILS_LOG_TO_STDOUT=true
# FORCE_SSL=true
