#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/check_coverage
#
# Enforces per-folder coverage thresholds for critical domain areas.
# Run after RSpec: bundle exec rspec && ruby bin/check_coverage
#
# Global 90% can be gamed by testing helpers and serializers.
# This script ensures the MONEY CODE is actually tested.
#
# Scaffold state: when total trackable lines < MIN_LINES_FOR_ENFORCEMENT,
# coverage checks are skipped with a warning (nothing meaningful to cover yet).

require 'json'

COVERAGE_FILE = 'coverage/.resultset.json'
LAST_RUN_FILE = 'coverage/.last_run.json'

# Minimum lines in a folder before enforcement kicks in.
# Folders with fewer lines are considered scaffold-only (base classes).
MIN_FOLDER_LINES = 10

# Critical folders with higher thresholds
CRITICAL_THRESHOLDS = {
  'app/services/orders'   => 95,
  'app/services/accounts' => 95,
  'app/services/yookassa' => 95,
  'app/jobs'              => 90,
  'app/mailers'           => 90,
  'app/models'            => 90,
}.freeze

# Base class files excluded from folder coverage (scaffold boilerplate)
SCAFFOLD_FILES = %w[
  application_record.rb
  application_job.rb
  application_mailer.rb
  application_controller.rb
].freeze

GLOBAL_THRESHOLD = 90

def main
  unless File.exist?(COVERAGE_FILE)
    warn "Coverage file not found: #{COVERAGE_FILE}"
    warn 'Run tests first: bundle exec rspec'
    exit 1
  end

  data = JSON.parse(File.read(COVERAGE_FILE))
  results = data.values.first
  return exit_no_data unless results && results['coverage']

  file_coverage = results['coverage']
  failures = []

  # Check per-folder thresholds
  CRITICAL_THRESHOLDS.each do |folder, threshold|
    folder_files = file_coverage.select do |path, _|
      path.include?(folder) && SCAFFOLD_FILES.none? { |base| path.end_with?(base) }
    end

    if folder_files.empty?
      puts "  SKIP  #{folder} (no domain files yet)"
      next
    end

    total_lines, covered_lines = count_coverage(folder_files)

    if total_lines < MIN_FOLDER_LINES
      puts "  SKIP  #{folder} (#{total_lines} lines < #{MIN_FOLDER_LINES} minimum)"
      next
    end

    percent = (covered_lines.to_f / total_lines * 100).round(2)
    status = percent >= threshold ? 'PASS' : 'FAIL'

    puts format('  %-6s %s: %.2f%% (threshold: %d%%)', status, folder, percent, threshold)

    if percent < threshold
      failures << { folder: folder, actual: percent, threshold: threshold }
    end
  end

  # Check global coverage (skip if only scaffold base classes exist)
  non_scaffold_lines = count_non_scaffold_lines(file_coverage)

  if non_scaffold_lines < MIN_FOLDER_LINES
    puts format("\n  SKIP  Global (%d non-scaffold lines < %d minimum)", non_scaffold_lines, MIN_FOLDER_LINES)
  elsif File.exist?(LAST_RUN_FILE)
    last_run = JSON.parse(File.read(LAST_RUN_FILE))
    global = last_run.dig('result', 'covered_percent')&.round(2)

    if global
      status = global >= GLOBAL_THRESHOLD ? 'PASS' : 'FAIL'
      puts format("\n  %-6s Global: %.2f%% (threshold: %d%%)", status, global, GLOBAL_THRESHOLD)

      if global < GLOBAL_THRESHOLD
        failures << { folder: 'GLOBAL', actual: global, threshold: GLOBAL_THRESHOLD }
      end
    end
  end

  puts

  if failures.any?
    warn 'Coverage gate FAILED:'
    failures.each do |f|
      warn "  #{f[:folder]}: #{f[:actual]}% < #{f[:threshold]}%"
    end
    exit 1
  else
    puts 'Coverage gate PASSED'
    exit 0
  end
end

def count_non_scaffold_lines(file_coverage)
  total = 0
  file_coverage.each do |path, lines|
    next if SCAFFOLD_FILES.any? { |base| path.end_with?(base) }

    line_data = lines.is_a?(Hash) ? lines['lines'] : lines
    next unless line_data.is_a?(Array)

    line_data.each { |hit| total += 1 unless hit.nil? }
  end
  total
end

def count_coverage(folder_files)
  total_lines = 0
  covered_lines = 0

  folder_files.each_value do |lines|
    line_data = lines.is_a?(Hash) ? lines['lines'] : lines
    next unless line_data.is_a?(Array)

    line_data.each do |hit|
      next if hit.nil?

      total_lines += 1
      covered_lines += 1 if hit.positive?
    end
  end

  [total_lines, covered_lines]
end

def exit_no_data
  warn 'No coverage data found in resultset'
  exit 1
end

main
