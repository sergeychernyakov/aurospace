#!/usr/bin/env bash
# bin/ci — Run ALL quality gates locally (1:1 mirror of .github/workflows/ci.yml)
#
# Usage: bin/ci           — all checks (skip Docker/Playwright if no scaffold)
#        bin/ci --fast    — backend only (skip Docker, frontend, e2e)

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0
SKIP=0

FAST_MODE=false
[[ "${1:-}" == "--fast" ]] && FAST_MODE=true

run_check() {
  local name=$1; shift
  printf "${BLUE}  ▸ %-36s${NC}" "$name"
  if OUTPUT=$("$@" 2>&1); then
    printf "${GREEN}PASS${NC}\n"
    PASS=$((PASS + 1))
  else
    printf "${RED}FAIL${NC}\n"
    echo "$OUTPUT" | tail -10
    echo ""
    FAIL=$((FAIL + 1))
  fi
}

run_skip() {
  local name=$1; local reason=$2
  printf "${BLUE}  ▸ %-36s${NC}${YELLOW}SKIP${NC} %s\n" "$name" "$reason"
  SKIP=$((SKIP + 1))
}

# ── Bootstrap Check ──────────────────────────────────────────
HAS_BACKEND=false
HAS_FRONTEND=false
HAS_SCHEMA=false
HAS_APP=false  # full app bootable (controllers + routes exist)

[ -f Gemfile.lock ] && [ -f config/routes.rb ] && HAS_BACKEND=true
[ -f frontend/package-lock.json ] && HAS_FRONTEND=true
([ -f db/schema.rb ] || ls db/migrate/*.rb >/dev/null 2>&1) && HAS_SCHEMA=true
[ -f app/controllers/orders_controller.rb ] && HAS_APP=true

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
echo -e "${BOLD}  AUROSPACE — Local Quality Gates (mirrors CI 1:1)${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
echo ""

# ── 1. Backend: Lint (CI: rubocop) ───────────────────────────
echo -e "${BOLD}  1. Backend: Lint${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "RuboCop"                      bundle exec rubocop --parallel --format simple
else
  run_skip "RuboCop"                       "(no Gemfile.lock)"
fi
echo ""

# ── 2. Backend: Security (CI: brakeman, bundle-audit, secret-scan) ──
echo -e "${BOLD}  2. Backend: Security${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "Brakeman"                     bundle exec brakeman -q --no-pager
  run_check "bundle-audit"                 bundle exec bundle-audit check --update
else
  run_skip "Brakeman"                      "(no Gemfile.lock)"
  run_skip "bundle-audit"                  "(no Gemfile.lock)"
fi

# Secret scan (always runs, like CI)
run_check "Secret scan" bash -c '
  MATCHES=$(grep -rn "BEGIN.*PRIVATE KEY" --include="*.rb" --include="*.yml" --include="*.json" --include="*.env" . 2>/dev/null \
    | grep -v ".github/workflows/" | grep -v "lefthook.yml" | grep -v "# Check for" \
    | grep -v "vendor/" | grep -v "node_modules/" || true)
  if [ -n "$MATCHES" ]; then echo "$MATCHES"; exit 1; fi
'
echo ""

# ── 3. Backend: Tests + Coverage (CI: rspec) ─────────────────
echo -e "${BOLD}  3. Backend: Tests + Coverage${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "RSpec"                        bundle exec rspec --format progress
  # Global coverage (same logic as CI)
  if [ -f coverage/.last_run.json ]; then
    run_check "Coverage (global 90%)" ruby -e '
      require "json"
      data = JSON.parse(File.read("coverage/.last_run.json"))
      pct = data.dig("result", "covered_percent") || 0
      puts "Coverage: #{pct.round(2)}%"
      exit(0) if pct.zero?
      exit(1) if pct < 90.0
    '
  else
    run_skip "Coverage (global 90%)"       "(no coverage data)"
  fi
  # Critical domain coverage
  if [ -x bin/check_coverage ] && [ -f coverage/.resultset.json ]; then
    run_check "Coverage (critical 95%)"    ruby bin/check_coverage
  else
    run_skip "Coverage (critical 95%)"     "(no coverage data)"
  fi
else
  run_skip "RSpec"                         "(no Gemfile.lock)"
  run_skip "Coverage (global 90%)"         "(no Gemfile.lock)"
  run_skip "Coverage (critical 95%)"       "(no Gemfile.lock)"
fi
echo ""

# ── 4. Backend: DB Quality (CI: database-consistency) ────────
echo -e "${BOLD}  4. Backend: DB Quality${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "database_consistency"         env RAILS_ENV=test bundle exec database_consistency
else
  run_skip "database_consistency"          "(no Gemfile.lock)"
fi
echo ""

# ── 5. Backend: Architecture (CI: architecture) ─────────────
echo -e "${BOLD}  5. Backend: Architecture${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "Architecture specs"           bundle exec rspec spec/architecture/ --format progress
  run_check "Packwerk"                     bundle exec packwerk validate
else
  run_skip "Architecture specs"            "(no Gemfile.lock)"
  run_skip "Packwerk"                      "(no Gemfile.lock)"
fi
echo ""

# ── 6. Backend: Docs (CI: yard-docs) ────────────────────────
echo -e "${BOLD}  6. Backend: Docs${NC}"
echo "  ───────────────────────────────────────────"
if $HAS_BACKEND; then
  run_check "YARD docs" bash -c 'bundle exec yard doc --quiet && bundle exec yard stats'
else
  run_skip "YARD docs"                     "(no Gemfile.lock)"
fi
echo ""

# ── 7. Docker (CI: hadolint, docker-build, docker-smoke) ────
echo -e "${BOLD}  7. Docker${NC}"
echo "  ───────────────────────────────────────────"
if $FAST_MODE; then
  run_skip "Hadolint"                      "(--fast mode)"
  run_skip "Docker build"                  "(--fast mode)"
  run_skip "Docker Compose smoke"          "(--fast mode)"
elif command -v docker > /dev/null 2>&1 && timeout 5 docker info > /dev/null 2>&1; then
  if command -v hadolint > /dev/null 2>&1; then
    run_check "Hadolint"                   hadolint Dockerfile
  else
    run_skip "Hadolint"                    "(not installed: brew install hadolint)"
  fi
  if $HAS_BACKEND; then
    run_check "Docker build"               docker build --target production -t aurospace:test .
  else
    run_skip "Docker build"                "(no Gemfile.lock)"
  fi
  if $HAS_APP; then
    run_check "Docker Compose smoke" bash -c '
      export SECRET_KEY_BASE=test_ci
      export FORCE_SSL=false
      docker compose down -v 2>/dev/null
      docker compose build app 2>/dev/null
      docker compose up -d --wait --wait-timeout 120 && \
      curl -sf http://localhost:3000/up && \
      docker compose down -v
    '
  else
    run_skip "Docker Compose smoke"        "(app not bootable yet — need controllers)"
  fi
else
  run_skip "Hadolint"                      "(Docker daemon not running)"
  run_skip "Docker build"                  "(Docker daemon not running)"
  run_skip "Docker Compose smoke"          "(Docker daemon not running)"
fi
echo ""

# ── 8. Frontend (CI: eslint, prettier, stylelint, typescript, frontend-tests) ──
echo -e "${BOLD}  8. Frontend${NC}"
echo "  ───────────────────────────────────────────"
if $FAST_MODE; then
  run_skip "ESLint"                        "(--fast mode)"
  run_skip "Prettier"                      "(--fast mode)"
  run_skip "Stylelint"                     "(--fast mode)"
  run_skip "TypeScript Strict"             "(--fast mode)"
  run_skip "Frontend Tests + Build"        "(--fast mode)"
elif $HAS_FRONTEND; then
  HAS_SRC=$([ -n "$(find frontend/src -name '*.ts' -o -name '*.tsx' 2>/dev/null)" ] && echo true || echo false)
  if $HAS_SRC; then
    run_check "ESLint"                     bash -c "cd frontend && npx eslint src/ --max-warnings 0"
    run_check "Prettier"                   bash -c "cd frontend && npx prettier --check 'src/**/*.{ts,tsx,js,jsx,css,scss,json}'"
    run_check "TypeScript Strict"          bash -c "cd frontend && npx tsc --noEmit"
  else
    run_skip "ESLint"                      "(no src/*.ts files yet)"
    run_skip "Prettier"                    "(no src/ files yet)"
    run_skip "TypeScript Strict"           "(no src/ files yet)"
  fi
  if [ -n "$(find frontend/src -name '*.css' -o -name '*.scss' 2>/dev/null)" ]; then
    run_check "Stylelint"                  bash -c "cd frontend && npx stylelint 'src/**/*.{css,scss}' --max-warnings 0"
  else
    run_skip "Stylelint"                   "(no CSS/SCSS files yet)"
  fi
  run_check "Frontend Tests + Build"       bash -c "cd frontend && npm run build"
else
  run_skip "ESLint"                        "(no package-lock.json)"
  run_skip "Prettier"                      "(no package-lock.json)"
  run_skip "Stylelint"                     "(no package-lock.json)"
  run_skip "TypeScript Strict"             "(no package-lock.json)"
  run_skip "Frontend Tests + Build"        "(no package-lock.json)"
fi
echo ""

# ── 9. E2E (CI: playwright) ─────────────────────────────────
echo -e "${BOLD}  9. E2E${NC}"
echo "  ───────────────────────────────────────────"
HAS_REAL_FRONTEND=$([ -f frontend/src/App.tsx ] && echo true || echo false)
if $FAST_MODE || ! $HAS_REAL_FRONTEND || ! $HAS_APP; then
  run_skip "Playwright E2E Smoke"          "(requires App.tsx + bootable app + Docker)"
elif command -v docker > /dev/null 2>&1 && timeout 5 docker info > /dev/null 2>&1; then
  run_check "Playwright E2E Smoke" bash -c '
    export SECRET_KEY_BASE=test_ci
    export FORCE_SSL=false
    export CI=1
    export BASE_URL=http://localhost:3000
    docker compose down -v 2>/dev/null
    docker compose build 2>/dev/null
    docker compose up -d --wait --wait-timeout 120 && \
    cd frontend && npx playwright install --with-deps chromium 2>/dev/null && \
    npx playwright test --project=chromium && \
    cd .. && docker compose down -v
  '
else
  run_skip "Playwright E2E Smoke"          "(Docker daemon not running)"
fi
echo ""

# ── 10. PR Automation (CI: danger) ──────────────────────────
echo -e "${BOLD}  10. PR Automation${NC}"
echo "  ───────────────────────────────────────────"
run_skip "Danger PR Check"                 "(runs only in CI on PRs)"
echo ""

# ── Summary ──────────────────────────────────────────────────
TOTAL=$((PASS + FAIL + WARN + SKIP))
echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
printf "  ${GREEN}PASS: %d${NC}  ${RED}FAIL: %d${NC}  ${YELLOW}SKIP: %d${NC}  Total: %d\n" \
  "$PASS" "$FAIL" "$SKIP" "$TOTAL"
echo -e "${BOLD}═══════════════════════════════════════════════════${NC}"
echo ""

if [ "$FAIL" -gt 0 ]; then
  echo -e "  ${RED}${BOLD}Quality gate FAILED.${NC}"
  echo ""
  exit 1
else
  echo -e "  ${GREEN}${BOLD}Quality gate PASSED.${NC}"
  echo ""
  exit 0
fi
